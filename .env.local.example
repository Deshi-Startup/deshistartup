# Copy this file to .env.local and fill in real values to run the
# contribution flow locally.
#
#   cp .env.local.example .env.local
#
# Never commit .env.local — it is gitignored.

# --- Google Sign-In (client-side, via Google Identity Services) ---
# https://console.cloud.google.com/apis/credentials — create an OAuth 2.0
# Client ID of type "Web application". Add your dev origin
# (e.g. http://localhost:3001) to "Authorized JavaScript origins".
# No client secret needed: login is fully client-side; the backend only
# verifies the Google-signed ID token.
#
# The NEXT_PUBLIC_ prefix exposes this to the browser (required for the
# "Sign in with Google" button). The backend reuses it as the audience
# when verifying the token.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- GitHub App (authors the contribution PRs) ---
# Create at: https://github.com/organizations/Deshi-Startup/settings/apps/new
#   (or under your user account settings → Developer settings → GitHub Apps)
# Repository permissions: Contents = Read & write, Pull requests = Read & write
# No webhooks needed. Install it on Deshi-Startup/deshistartup.
GITHUB_APP_ID=
# The PEM private key. Paste with real newlines, OR keep the \n escapes —
# both are handled. Keep it secret.
GITHUB_APP_PRIVATE_KEY=
# Numeric installation ID (from the app's install page URL, or the API).
GITHUB_INSTALLATION_ID=

# --- Optional overrides ---
# GITHUB_REPO=Deshi-Startup/deshistartup
