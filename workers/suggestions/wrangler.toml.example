name = "deshi-startup-suggestions"
main = "src/index.js"
compatibility_date = "2026-07-05"

[vars]
GITHUB_REPO = "Deshi-Startup/deshistartup"
GITHUB_BRANCH = "main"
ALLOWED_ORIGINS = "https://deshi-startup.github.io,http://localhost:3000"
REQUIRE_TURNSTILE = "true"

# Set these as encrypted secrets:
# wrangler secret put GITHUB_TOKEN
# wrangler secret put TURNSTILE_SECRET_KEY

# Optional Cloudflare Rate Limiting binding. Replace namespace_id before use.
# [[unsafe.bindings]]
# name = "RATE_LIMITER"
# type = "ratelimit"
# namespace_id = "1001"
# simple = { limit = 5, period = 60 }
