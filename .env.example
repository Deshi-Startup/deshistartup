# Public site variables used by the contribution form.
NEXT_PUBLIC_SUGGESTION_API_URL=https://your-worker.example.com/suggestions
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Public suggestion Worker secrets and variables.
GITHUB_TOKEN=github-token-with-issues-permission
GITHUB_REPO=Deshi-Startup/deshistartup
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
ALLOWED_ORIGINS=https://deshi-startup.github.io

# Decap CMS OAuth Worker secrets and variables.
GITHUB_OAUTH_CLIENT_ID=github-oauth-client-id
GITHUB_OAUTH_CLIENT_SECRET=github-oauth-client-secret
OAUTH_STATE_SECRET=long-random-state-signing-secret
SITE_ORIGIN=https://deshi-startup.github.io
ALLOWED_SITE_IDS=deshi-startup.github.io
