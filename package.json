    "nextra-theme-docs": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "cheerio": "^1.2.0",
    "node-fetch": "^3.3.2",
    "pagefind": "^1.5.2",
    "robots-parser": "^3.0.1",
    "turndown": "^7.2.4"
